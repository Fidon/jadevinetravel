msgstr "Доступны через WhatsApp круглосуточно"

#: .\templates\core\about.html:113
msgid "What Drives Us"
msgstr "Что нас движет"

#: .\templates\core\about.html:115
msgid "Mission &"
msgstr "Миссия и"

#: .\templates\core\about.html:115
msgid "Vision"
